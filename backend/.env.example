# ==============================================
# A-LINKS Backend Environment Variables
# ==============================================

# NODE ENVIRONMENT
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:8080

# ==============================================
# DATABASE (PostgreSQL)
# ==============================================
DATABASE_URL=postgresql://alinks_user:alinks_password_2026@localhost:5432/alinks

# ==============================================
# JWT TOKENS
# ==============================================
# Access token secret (use a strong random string in production)
# Generate with: openssl rand -base64 32
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-change-this-in-production
ACCESS_TOKEN_EXPIRY=15m

# Refresh token expiry (7-30 days recommended)
REFRESH_TOKEN_EXPIRY=7d

# ==============================================
# EMAIL (Nodemailer - Gmail SMTP)
# ==============================================
# To use with Gmail:
# 1. Enable 2-factor authentication on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character password below (without spaces)
#
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-16-chars
EMAIL_FROM=noreply@alinks.org

# ==============================================
# CLOUDINARY (Image Hosting)
# ==============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==============================================
# SMS (Optional - Twilio for SMS notifications)
# ==============================================
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE=+1234567890

# ==============================================
# LOGGING & DEBUGGING
# ==============================================
DEBUG=false
LOG_LEVEL=debug
